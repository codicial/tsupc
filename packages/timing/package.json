{
  "name": "@tsupc/timing",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codicial/tsupc.git",
    "directory": "packages/timing"
  },
  "license": "MIT",
  "version": "0.0.1",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
